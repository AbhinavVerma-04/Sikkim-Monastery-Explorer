        const created = await Monastery.insertMany(monasteries);

        res.json({
            success: true,
            message: `Successfully seeded ${created.length} monasteries`,
            data: created
        });
    } catch (err) {
        res.status(400).json({
            success: false,
            message: 'Error seeding monasteries: ' + err.message
        });
    }
});

module.exports = monasteryRouter;
